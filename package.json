{
  "name": "lg-webos-magic-touchpad-card",
  "version": "0.2.2",
  "description": "Home Assistant Lovelace custom card for LG webOS Magic Remote pointer control.",
  "type": "module",
  "files": [
    "dist",
    "src",
    "server",
    "examples",
    "hacs.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:dist && npm run build:integration",
    "build:dist": "esbuild src/lg-webos-magic-touchpad-card.ts --bundle --format=esm --target=es2021 --outfile=dist/lg-webos-magic-touchpad-card.js",
    "build:integration": "esbuild src/lg-webos-magic-touchpad-card.ts --bundle --format=esm --target=es2021 --outfile=custom_components/lg_webos_magic_touchpad/www/lg-webos-magic-touchpad-card.js",
    "check": "tsc --noEmit",
    "watch": "npm run build -- --watch"
  },
  "keywords": [
    "home-assistant",
    "hacs",
    "lovelace",
    "lg",
    "webos",
    "magic-remote"
  ],
  "author": "Francesco Iazzetti",
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "lit": "^3.2.0"
  }
}
